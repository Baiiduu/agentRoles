# Copy this file to .env and fill in your real keys for local testing.

AGENTSROLES_OPENAI_API_KEY=your-openai-key
AGENTSROLES_OPENAI_BASE_URL=https://api.openai.com/v1
AGENTSROLES_OPENAI_MODEL=gpt-5

# Optional OpenAI organization metadata
AGENTSROLES_OPENAI_PROJECT=
AGENTSROLES_OPENAI_ORG=

AGENTSROLES_DEEPSEEK_API_KEY=your-deepseek-key
AGENTSROLES_DEEPSEEK_BASE_URL=https://api.deepseek.com
AGENTSROLES_DEEPSEEK_MODEL=deepseek-chat

# Optional. If omitted, provider defaults are used.
AGENTSROLES_DEFAULT_LLM_PROFILE=openai.default

# Persistence: sqlite is the recommended default for the current local prototype.
# MySQL is not the same thing as SQLite. If you later switch backend, keep the
# same repository contracts and replace only the infrastructure adapter.
AGENTSROLES_PERSISTENCE_BACKEND=sqlite
AGENTSROLES_STORAGE_ROOT=E:\agentsRolesData
AGENTSROLES_SQLITE_PATH=E:\agentsRolesData\db\agents_roles.sqlite3
AGENTSROLES_FILES_ROOT=E:\agentsRolesData\files
AGENTSROLES_AUTH_ROOT=E:\agentsRolesData\auth
AGENTSROLES_DEFAULT_WORKSPACE_ROOT=E:\agentsRolesData\files\agent_workspaces
